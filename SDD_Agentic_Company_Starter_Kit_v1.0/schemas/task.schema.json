{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task Record",
  "type": "object",
  "required": [
    "id",
    "description",
    "requirements",
    "status",
    "evidence"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^TASK-[0-9]{3,}$"
    },
    "description": {
      "type": "string"
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "enum": [
        "Draft",
        "Ready",
        "In Progress",
        "Blocked",
        "Review",
        "Done"
      ]
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
