{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Requirement Record",
  "type": "object",
  "required": [
    "id",
    "statement",
    "priority",
    "acceptance_criteria"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(REQ|NFR|SEC|DATA|OPS)-[A-Z0-9-]+-[0-9]{3,}$"
    },
    "statement": {
      "type": "string",
      "minLength": 10
    },
    "priority": {
      "enum": [
        "Must",
        "Should",
        "Could",
        "Won't"
      ]
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "source": {
      "type": "string"
    },
    "status": {
      "enum": [
        "Draft",
        "Approved",
        "Implemented",
        "Verified",
        "Rejected"
      ]
    }
  }
}
